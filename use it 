from typing import TypedDict, Annotated, Dict, Any
from langgraph.graph import StateGraph, START
from langgraph.graph.message import add_messages
from langchain_core.messages import AnyMessage

from agents.analyst_agent import get_analyst_app
from agents.expert_agent import get_expert_app
from agents.reviewer_agent import get_reviewer_app

class SupervisorState(TypedDict):
    messages: Annotated[list[AnyMessage], add_messages]
    step: int
    next_node: str
    db_config: Dict[str, Any]

def supervisor(state):

    s = state["step"]

    nxt = {
        0: "analyst",
        1: "expert",
        2: "reviewer"
    }.get(s, "__end__")

    return {
        "messages": state["messages"],
        "step": s + 1,
        "next_node": nxt,
        "db_config": state["db_config"]
    }

def route(state):
    return state["next_node"]

def call_analyst(state):
    return get_analyst_app().invoke({"messages":state["messages"]})

def call_expert(state):
    return get_expert_app(state["db_config"]).invoke({"messages":state["messages"]})

def call_reviewer(state):
    return get_reviewer_app().invoke({"messages":state["messages"]})

def get_supervisor_app(db_config):

    g = StateGraph(SupervisorState)

    g.add_node("supervisor", supervisor)
    g.add_node("analyst", call_analyst)
    g.add_node("expert", call_expert)
    g.add_node("reviewer", call_reviewer)

    g.add_edge(START, "supervisor")
    g.add_conditional_edges("supervisor", route)

    g.add_edge("analyst", "supervisor")
    g.add_edge("expert", "supervisor")
    g.add_edge("reviewer", "supervisor")

    app = g.compile()

    class Wrapped:
        def invoke(self, payload):
            payload["db_config"] = db_config
            return app.invoke(payload)

    return Wrapped()



